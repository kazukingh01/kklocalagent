# Copy to .env and edit. Picked up automatically by `docker compose`
# in this directory. Only used by compose.online.yaml.

# Hostname / IP at which audio-io (running natively on Windows) is
# reachable from the WSL2 docker network.
#
# - host.docker.internal works on Docker Desktop and on docker-ce with
#   the WSL2 backend (Docker 20.10+).
# - On other setups, set the explicit Windows IP, e.g.
#     WINDOWS_HOST=192.168.1.42
#   Find it from PowerShell on Windows:   `ipconfig | Select-String IPv4`
#   Or from inside WSL2 (default route = Windows host):
#     ip route show | awk '/default/ {print $3}'
WINDOWS_HOST=host.docker.internal
