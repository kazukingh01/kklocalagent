# Environment overrides for the root `compose.yaml`. Copy to `.env`
# (which compose loads automatically) and adjust per-host. Every
# variable here has a working default in compose.yaml — `.env` is
# only needed when the default doesn't match the local setup.
#
#   cp .env.example .env
#   # edit .env
#   docker compose up -d --build
#
# `.env` is gitignored; this file (`.env.example`) is the canonical
# documentation of what each variable does and which services see it.

# -----------------------------------------------------------------------
# COMPOSE_FILE — compose flavor selector.
#
#   compose.yaml                       — production GPU stack (default)
#   compose.yaml:compose.cpu.yaml      — CPU-only: drops the LLM GPU
#                                         reservation and swaps to
#                                         gemma3:1b for low-RAM hosts
#
# Setting this here avoids having to type `-f compose.yaml -f ...` on
# every `docker compose` invocation. Override on the CLI with
# `docker compose -f ... -f ... up`.
#
# Default: compose.yaml (GPU)
#COMPOSE_FILE=compose.yaml:compose.cpu.yaml

# -----------------------------------------------------------------------
# WINDOWS_HOST — how WSL2 containers reach the audio-io binary running
# on the Windows host (audio-io is Windows-native and lives outside
# compose). Affects VAD, wake-word-detection, and tts-streamer:
#
#   VAD              ws://${WINDOWS_HOST}:7010/mic     (subscribe)
#   wake-word        ws://${WINDOWS_HOST}:7010/mic     (subscribe)
#   tts-streamer     ws://${WINDOWS_HOST}:7010/spk     (publish)
#                    http://${WINDOWS_HOST}:7010       (POST /start)
#
# Pick one of:
#   host.docker.internal  — works on Docker Desktop and on docker-ce
#                           with the WSL2 backend (the default).
#   <literal IP>          — needed on plain Linux docker, or when
#                           audio-io is on a different LAN host. Use
#                           the IP that audio-io's `[server] host`
#                           binds to.
#
# Default: host.docker.internal
#WINDOWS_HOST=host.docker.internal
#WINDOWS_HOST=192.168.1.42

# -----------------------------------------------------------------------
# LLM_MODEL — what `llm` (ollama) pulls at startup, and what
# `orchestrator` names in /api/chat requests. Both services see the
# same value via a YAML anchor in compose.yaml — never set them
# separately. Must match an ollama tag (library or HF GGUF):
#
#   gemma3:4b                                              (production default, ~3.3 GB)
#   gemma3:1b                                              (smoke test, ~815 MB)
#   hf.co/mmnga-o/llm-jp-4-8b-thinking-gguf:Q8_0           (Japanese, ~9 GB)
#   hf.co/unsloth/Qwen3.6-35B-A3B-GGUF:Q3_K_M              (caveats — see llm/README.md)
#
# Default: gemma3:4b
#LLM_MODEL=gemma3:4b

# -----------------------------------------------------------------------
# ASR_MODEL — whisper.cpp GGML model file. Fetched into the
# `asr-models` volume on first run. Must exist as a file at
# `https://huggingface.co/ggerganov/whisper.cpp/resolve/main/<name>`:
#
#   ggml-small-q8_0.bin               (default, ~252 MB, decent JP)
#   ggml-medium-q5_0.bin              (~514 MB, better accuracy)
#   ggml-large-v3-turbo-q5_0.bin      (~547 MB, best non-realtime)
#   ggml-base.en.bin                  (~145 MB, English-only)
#
# See `automatic-speech-recognition/README.md` for the full list and
# the runtime/quality trade-offs.
#
# Default: ggml-small-q8_0.bin
#ASR_MODEL=ggml-small-q8_0.bin

# -----------------------------------------------------------------------
# Wake state-machine windows. The orchestrator's v1.0 gate has two
# distinct timers; either expiring without an event resets the state
# to Idle (operator must re-wake).
#
#   ORCH_WAKE_WINDOW_MS         — after a WakeWordDetected, how long
#                                  to wait for VAD's SpeechStarted.
#                                  Default 5000 ms.
#   ORCH_TURN_FOLLOWUP_WINDOW_MS — after a Turn finishes (TTS end /
#                                  any natural exit), how long to
#                                  wait for the *next* SpeechStarted
#                                  before requiring a fresh wake.
#                                  Default 10000 ms.
#
# Raise either window if the operator tends to pause / think before
# speaking. Lower them for tighter "false-positive whisper noise"
# protection.
#ORCH_WAKE_WINDOW_MS=5000
#ORCH_TURN_FOLLOWUP_WINDOW_MS=10000

# -----------------------------------------------------------------------
# ORCH_WAKE_REQUIRED — when true (default), the wake state machine
# is active: only utterances that follow a recent WakeWordDetected
# (or fall in the post-turn follow-up window) reach ASR/LLM/TTS.
# Set to false to fall back to v0.1 always-listening mode (every
# SpeechEnded triggers the pipeline). Useful for headless tests or
# hosts where the wake-word model isn't available.
#ORCH_WAKE_REQUIRED=true

# -----------------------------------------------------------------------
# ORCH_WAKE_BARGE_IN — when true (default), a WakeWordDetected event
# arriving while a Turn is in flight cancels the in-flight TTS via
# tts-streamer's /stop endpoint and immediately re-arms with the
# wake window — the operator interrupts the assistant's reply with
# a fresh question.
#
# Set to false for "uninterruptible" UX: a mid-turn wake is recorded
# (the next state will be ArmedAfterWake) but doesn't cut the
# current reply.
#ORCH_WAKE_BARGE_IN=false

# -----------------------------------------------------------------------
# WW_MODELS — comma-separated list of openWakeWord models to load.
# Each name corresponds to a wake phrase the model was trained on.
# Bundled options (English only — openWakeWord has no Japanese
# wake-word models out of the box):
#
#   alexa         "Alexa"
#   hey_jarvis    "Hey Jarvis"     (default)
#   hey_mycroft   "Hey Mycroft"
#   hey_rhasspy   "Hey Rhasspy"
#
# Multiple models can be active simultaneously; the highest score
# across all loaded models is checked against WW_THRESHOLD per
# 80 ms inference window. So `alexa,hey_jarvis` lets the operator
# use either phrase. Loading more models proportionally increases
# CPU per chunk.
#
# For a Japanese wake word: openWakeWord supports custom training
# (see https://github.com/dscripka/openWakeWord/blob/main/docs/training_models.md)
# but the default image only has the English models above.
#
# Default: hey_jarvis
#WW_MODELS=alexa
#WW_MODELS=alexa,hey_jarvis

# -----------------------------------------------------------------------
# WW_THRESHOLD — wake-word detection score threshold (0.0–1.0). The
# default 0.5 is openWakeWord's recommended balance between false
# triggers and miss rate. Lower it (0.3, 0.2) if "alexa" doesn't
# trigger reliably for your mic / accent; raise it (0.7) if random
# speech accidentally fires the wake.
#
# Default: 0.5
#WW_THRESHOLD=0.4

# -----------------------------------------------------------------------
# WW_PEAK_LOG_INTERVAL_SEC — wake-word diagnostic log knob. When > 0,
# the wake-word service periodically logs the highest score it saw
# in each window, regardless of whether the threshold was crossed.
# Use this to tune WW_THRESHOLD: say "alexa" a few times, watch the
# log, see what scores your voice produces, set the threshold a
# little below the lowest one that mattered.
#
# Off by default (0) — production wake stays silent until it fires.
#
#   5.0   — light diagnostic during a tuning session
#   1.0   — aggressive (chatty); use when nothing seems to fire
#   0     — off (default)
#WW_PEAK_LOG_INTERVAL_SEC=5

# -----------------------------------------------------------------------
# ORCH_LLM_SYSTEM_PROMPT — voice-assistant persona prepended to every
# chat as {role:"system"}. Empty string disables the system message
# entirely (the LLM is sent only the user turn). Default in
# compose.yaml is the English voice-friendly persona; override here
# to change tone, switch primary language, or specialise (e.g.
# "you are a kitchen timer assistant").
#
# The default tells the model:
#   - replies are spoken aloud (no markdown / lists / code blocks)
#   - keep responses short (1–2 sentences)
#   - default to Japanese unless the user clearly speaks another language
#   - maintain a brisk, natural conversational rhythm
#
# Single-line only — `.env` files don't support multiline values; if
# you need multi-paragraph instructions, set this in the compose
# environment block directly (which supports YAML literal blocks).
#ORCH_LLM_SYSTEM_PROMPT=You are a voice assistant; your replies are spoken aloud, so write the way people speak — no markdown, no lists, no code blocks. Keep every response to one or two short sentences. Default to Japanese (日本語) unless the user clearly speaks another language. Maintain a brisk, natural conversational rhythm.
