# Environment overrides for the root `compose.yaml`. Copy to `.env`
# (which compose loads automatically) and adjust per-host. Every
# variable here has a working default in compose.yaml — `.env` is
# only needed when the default doesn't match the local setup.
#
#   cp .env.example .env
#   # edit .env
#   docker compose up -d --build
#
# `.env` is gitignored; this file (`.env.example`) is the canonical
# documentation of what each variable does and which services see it.

# -----------------------------------------------------------------------
# COMPOSE_FILE — compose flavor selector.
#
#   compose.yaml                       — production GPU stack (default)
#   compose.yaml:compose.cpu.yaml      — CPU-only: drops the LLM GPU
#                                         reservation and swaps to
#                                         gemma3:1b for low-RAM hosts
#
# Setting this here avoids having to type `-f compose.yaml -f ...` on
# every `docker compose` invocation. Override on the CLI with
# `docker compose -f ... -f ... up`.
#
# Default: compose.yaml (GPU)
#COMPOSE_FILE=compose.yaml:compose.cpu.yaml

# -----------------------------------------------------------------------
# WINDOWS_HOST — how WSL2 containers reach the audio-io binary running
# on the Windows host (audio-io is Windows-native and lives outside
# compose). Affects VAD, wake-word-detection, and tts-streamer:
#
#   VAD              ws://${WINDOWS_HOST}:7010/mic     (subscribe)
#   wake-word        ws://${WINDOWS_HOST}:7010/mic     (subscribe)
#   tts-streamer     ws://${WINDOWS_HOST}:7010/spk     (publish)
#                    http://${WINDOWS_HOST}:7010       (POST /start)
#
# Pick one of:
#   host.docker.internal  — works on Docker Desktop and on docker-ce
#                           with the WSL2 backend (the default).
#   <literal IP>          — needed on plain Linux docker, or when
#                           audio-io is on a different LAN host. Use
#                           the IP that audio-io's `[server] host`
#                           binds to.
#
# Default: host.docker.internal
#WINDOWS_HOST=host.docker.internal
#WINDOWS_HOST=192.168.1.42

# -----------------------------------------------------------------------
# LLM_MODEL — what `llm` (ollama) pulls at startup, and what
# `orchestrator` names in /api/chat requests. Both services see the
# same value via a YAML anchor in compose.yaml — never set them
# separately. Must match an ollama tag (library or HF GGUF):
#
#   gemma4:e4b                                             (production default, ~9.6 GB Q4_K_M)
#   gemma4:e2b                                             (lighter gemma4, voice-friendly)
#   gemma4:26b                                             (MoE A4B; 26B capacity at ~4B inference cost, ~16 GB)
#   gemma4:31b                                             (top-tier dense, ~20 GB)
#   gemma3:4b                                              (legacy default, ~3.3 GB)
#   gemma3:1b                                              (smoke test, ~815 MB)
#   hf.co/mmnga-o/llm-jp-4-8b-thinking-gguf:Q8_0           (Japanese, ~9 GB)
#   hf.co/unsloth/Qwen3.6-35B-A3B-GGUF:Q3_K_M              (caveats — see llm/README.md)
#
# Default: gemma4:e4b
#LLM_MODEL=gemma4:e4b

# -----------------------------------------------------------------------
# ASR_MODEL — whisper.cpp GGML model file. Fetched into the
# `asr-models` volume on first run. Must exist as a file at
# `https://huggingface.co/ggerganov/whisper.cpp/resolve/main/<name>`:
#
#   ggml-small-q8_0.bin               (CPU compose default, ~252 MB)
#   ggml-medium-q8_0.bin              (GPU default, ~824 MB)
#   ggml-medium-q5_0.bin              (~514 MB, lighter quant)
#   ggml-large-v3-turbo-q8_0.bin      (~1.6 GB, best JP accuracy,
#                                       +100–200 ms inference vs
#                                       medium on a 4090-class GPU)
#   ggml-large-v3-turbo-q5_0.bin      (~547 MB)
#   ggml-base.en.bin                  (~145 MB, English-only)
#
# Trade-off summary for short voice-agent prompts:
#   small           → fastest, accuracy struggles on Japanese
#   medium          → ~100–200 ms slower than small, much better JP,
#                     ~100–200 ms faster than large-v3-turbo
#   large-v3-turbo  → best JP, slowest of the three
#
# See `automatic-speech-recognition/README.md` for the full list and
# the runtime/quality trade-offs.
#
# Defaults: ggml-medium-q8_0.bin (GPU compose), ggml-small-q8_0.bin
#           (CPU override — keeps the asr-models download light when
#            no GPU is available)
#ASR_MODEL=ggml-large-v3-turbo-q8_0.bin

# -----------------------------------------------------------------------
# VOICEVOX_SPEED_SCALE — multiplier on the assistant's speech speed.
# tts-streamer fetches an AudioQuery from VOICEVOX, sets this on the
# `speedScale` field, then sends it to /synthesis. 1.0 is engine
# default; 1.5 makes the agent speak 50% faster (brisker, less
# patient feel — fits a voice-command UI). VOICEVOX accepts roughly
# 0.5–2.0 reliably; values outside that range may distort prosody.
#
# Default: 1.0
#VOICEVOX_SPEED_SCALE=1.5

# -----------------------------------------------------------------------
# Wake state-machine windows. The orchestrator's v1.0 gate has two
# distinct timers; either expiring without an event resets the state
# to Idle (operator must re-wake).
#
#   ORCH_WAKE_WINDOW_MS         — after a WakeWordDetected, how long
#                                  to wait for VAD's SpeechStarted.
#                                  Default 5000 ms.
#   ORCH_TURN_FOLLOWUP_WINDOW_MS — after a Turn finishes (TTS end /
#                                  any natural exit), how long to
#                                  wait for the *next* SpeechStarted
#                                  before requiring a fresh wake.
#                                  Default 10000 ms.
#
# Raise either window if the operator tends to pause / think before
# speaking. Lower them for tighter "false-positive whisper noise"
# protection.
#ORCH_WAKE_WINDOW_MS=5000
#ORCH_TURN_FOLLOWUP_WINDOW_MS=10000

# -----------------------------------------------------------------------
# ORCH_WAKE_REQUIRED — when true (default), the wake state machine
# is active: only utterances that follow a recent WakeWordDetected
# (or fall in the post-turn follow-up window) reach ASR/LLM/TTS.
# Set to false to fall back to v0.1 always-listening mode (every
# SpeechEnded triggers the pipeline). Useful for headless tests or
# hosts where the wake-word model isn't available.
#ORCH_WAKE_REQUIRED=true

# -----------------------------------------------------------------------
# ORCH_WAKE_BARGE_IN — when true (default), a WakeWordDetected event
# arriving while a Turn is in flight cancels the in-flight TTS via
# tts-streamer's /stop endpoint and immediately re-arms with the
# wake window — the operator interrupts the assistant's reply with
# a fresh question.
#
# Set to false for "uninterruptible" UX: a mid-turn wake is recorded
# (the next state will be ArmedAfterWake) but doesn't cut the
# current reply.
#ORCH_WAKE_BARGE_IN=false

# -----------------------------------------------------------------------
# ORCH_POST_WAKE_SE_DROPOUT_MS — drop SpeechEnded events that arrive
# within this many milliseconds of the most recent WakeWordDetected.
# Targets the "VAD captures the wake word's own audio" case: with no
# dropout, saying just "Hey Jarvis" produces a SE ~300 ms later (VAD
# silence hangover) whose audio is the wake word itself; the
# orchestrator otherwise dispatches a turn whose ASR text is "Jervis"
# and the LLM treats it as a real query.
#
# 800 ms (the default) covers the wake-word-only case but lets a
# continuous "Hey Jarvis, what's the weather?" through, since VAD's
# hangover pushes that SE to >1 s after the wake fires. State stays
# armed when an SE is dropped, so the operator's actual follow-up
# utterance still triggers the pipeline within the wake window.
#
# Set to 0 to disable (every SE that passes the wake gate dispatches,
# matching the v1.0 behaviour before this knob existed). Bump higher
# if you've observed SE events landing past 800 ms that still capture
# only the wake word — depends on your VAD hangover and how slowly
# you trail off the wake phrase.
#
# Only honoured when ORCH_WAKE_REQUIRED=true.
#
# Default: 800
#ORCH_POST_WAKE_SE_DROPOUT_MS=1200

# -----------------------------------------------------------------------
# ORCH_TTS_TAIL_QUIET_MS — drop ALL VAD events (SpeechStarted and
# SpeechEnded) for this many milliseconds after each turn's TTS
# completes. With /finalize giving the orchestrator the precise
# speaker-silent moment, this only has to cover VAD's silence
# hangover (~200 ms for the default VAD_HANG_FRAMES=10) plus a
# small propagation margin. Without it the trailing SE — which
# always fires `hangover` ms after the audio stops — would dispatch
# an echo turn whose ASR text is the tail of the assistant's reply.
#
# WakeWordDetected is *not* gated by this — the operator deliberately
# barging in mid-playback is the case the gate must let through.
#
# Defaults to 400 ms (covers VAD_HANG_FRAMES up to ~15). Bump to
# 600+ if you've raised VAD_HANG_FRAMES to 20 or more.
#
# Default: 400
#ORCH_TTS_TAIL_QUIET_MS=600

# -----------------------------------------------------------------------
# ORCH_ASR_HALLUCINATION_BLACKLIST — pipe-separated substring list.
# If the transcribed ASR text *contains* any of these strings, the
# turn is dropped exactly like an empty transcription (no LLM call,
# no TTS, no sink TurnCompleted). Whisper hallucinates these stock
# YouTube end-of-video phrases on ambiguous quiet input — none are
# plausible voice-agent commands so blocking is safe.
#
# Substring matching catches punctuated and trailing-text variants
# in one rule each ("ご視聴ありがとう" matches both
# "ご視聴ありがとうございました" and "ご視聴ありがとうございました!").
#
# Defaults baked in: "ご視聴ありがとう", "(拍手)", "(笑)",
# "Thanks for watching", "Subscribe to my channel".
#
# Override here to add domain-specific extras (the env *replaces*,
# not augments, the default list — include the defaults if you want
# to keep them). Set to empty (`ORCH_ASR_HALLUCINATION_BLACKLIST=`)
# to disable filtering entirely.
#
# Default: ご視聴ありがとう|(拍手)|(笑)|Thanks for watching|Subscribe to my channel
#ORCH_ASR_HALLUCINATION_BLACKLIST=ご視聴ありがとう|(拍手)|(笑)|字幕は提供されていません|Thanks for watching|Subscribe to my channel

# -----------------------------------------------------------------------
# WW_MODELS — comma-separated list of openWakeWord models to load.
# Each name corresponds to a wake phrase the model was trained on.
# Bundled options (English only — openWakeWord has no Japanese
# wake-word models out of the box):
#
#   alexa         "Alexa"
#   hey_jarvis    "Hey Jarvis"     (default)
#   hey_mycroft   "Hey Mycroft"
#   hey_rhasspy   "Hey Rhasspy"
#
# Multiple models can be active simultaneously; the highest score
# across all loaded models is checked against WW_THRESHOLD per
# 80 ms inference window. So `alexa,hey_jarvis` lets the operator
# use either phrase. Loading more models proportionally increases
# CPU per chunk.
#
# For a Japanese wake word: openWakeWord supports custom training
# (see https://github.com/dscripka/openWakeWord/blob/main/docs/training_models.md)
# but the default image only has the English models above.
#
# Default: hey_jarvis
#WW_MODELS=alexa
#WW_MODELS=alexa,hey_jarvis

# -----------------------------------------------------------------------
# WW_THRESHOLD — wake-word detection score threshold (0.0–1.0). The
# default 0.5 is openWakeWord's recommended balance between false
# triggers and miss rate. Lower it (0.3, 0.2) if "alexa" doesn't
# trigger reliably for your mic / accent; raise it (0.7) if random
# speech accidentally fires the wake.
#
# Default: 0.5
#WW_THRESHOLD=0.4

# -----------------------------------------------------------------------
# WW_PEAK_LOG_INTERVAL_SEC — wake-word diagnostic log knob. When > 0,
# the wake-word service periodically logs the highest score it saw
# in each window, regardless of whether the threshold was crossed.
# Use this to tune WW_THRESHOLD: say "alexa" a few times, watch the
# log, see what scores your voice produces, set the threshold a
# little below the lowest one that mattered.
#
# Off by default (0) — production wake stays silent until it fires.
#
#   5.0   — light diagnostic during a tuning session
#   1.0   — aggressive (chatty); use when nothing seems to fire
#   0     — off (default)
#WW_PEAK_LOG_INTERVAL_SEC=5

# -----------------------------------------------------------------------
# VAD_HANG_FRAMES — silence hangover before VAD fires SpeechEnded,
# in 20 ms frames. Each frame is detector.frame_ms (default 20 ms),
# so 10 ≈ 200 ms, 20 ≈ 400 ms.
#
# Lowering this cuts end-of-utterance latency 1:1 (the 20→10 change
# in compose.yaml shaves ~200 ms from every turn's SE→ASR boundary)
# but risks splitting a single thought into two utterances when the
# operator pauses mid-sentence ("えーと、…それで…"). Tune up if the
# agent starts replying before you finish your question.
#
# Default: 10 (≈ 200 ms — voice-agent commands tend to be short and
#                latency dominates)
#
#   5     — very aggressive, ~100 ms; only for crisp short queries
#   10    — default, ~200 ms
#   20    — library default, ~400 ms; safer for natural speech
#   30    — ~600 ms; users who pause noticeably between words
#VAD_HANG_FRAMES=20

# -----------------------------------------------------------------------
# VAD_START_FRAMES — consecutive voiced 20 ms frames required before
# SpeechStarted fires. Default 3 (~60 ms) is permissive: a single
# clap or sharp tap (~80–120 ms) crosses it and dispatches a turn
# whose ASR text is whatever Whisper hallucinates from the impulse.
#
# Bump to filter impulse / transient noise out at the gate:
#   3   — default, most responsive
#   5   — ~100 ms, swallows most single claps and mouse clicks
#   7   — ~140 ms, swallows even loud knock / door close
#
# Trade-off: higher values eat the leading frames of very fast
# utterance onsets ("はい") so the first phoneme can be clipped in
# the audio buffer that ASR receives.
#
# Default: 3
#VAD_START_FRAMES=5

# -----------------------------------------------------------------------
# VAD_AGGRESSIVENESS — webrtc-vad internal strictness, 0..=3.
#   0  Quality         most permissive (calls more frames "speech")
#   1  LowBitrate
#   2  Aggressive      default (balanced)
#   3  VeryAggressive  strictest, drops more borderline frames
#
# Bump to 3 in noisy environments; combined with VAD_START_FRAMES
# it's a cheap impulse-noise defense before reaching for energy
# gates or spectral filters.
#
# Default: 2
#VAD_AGGRESSIVENESS=3

# -----------------------------------------------------------------------
# VAD_DENOISE — when true, every incoming 20 ms audio frame is run
# through nnnoiseless (RNNoise port) before VAD classification AND
# before being buffered for ASR. ML-based speech enhancement that
# suppresses steady-state background (fans, AC, low keyboard hum)
# while preserving voice. Two big payoffs:
#
#   1. Fewer VAD false positives — quiet rooms with constant fan
#      noise stop randomly tripping SpeechStarted.
#   2. Whisper hallucinates less on noisy near-silence. Whisper
#      tends to fill ambiguous quiet audio with Japanese YouTube
#      boilerplate ("ご視聴ありがとうございました", "(拍手)",
#      "Thanks for watching"); a denoise pre-stage materially cuts
#      the rate.
#
# Cost: ~0.5% of one CPU core at the 50-frames-per-second pipeline
# rate, plus ~10 ms of added latency from the 16 k → 48 k → 16 k
# resampling that RNNoise needs (it processes 48 kHz only).
#
# Off by default — flip on if your mic environment has noticeable
# steady noise or Whisper hallucinations are a recurring problem.
#
# Default: false
#VAD_DENOISE=true

# -----------------------------------------------------------------------
# VAD_MIN_UTTERANCE_RMS_DBFS — SpeechEnded events whose buffered
# audio has RMS below this dBFS value are dropped at the VAD layer
# (the orchestrator never sees them, ASR never runs).
#
# dBFS reference (mic-side, post-RNNoise if enabled):
#   -10..-25  normal speech into mic
#   -25..-40  quiet speech / far mic / whisper
#   -45       ←← typical recommended threshold
#   -50..-60  pure ambient noise, no one talking
#
# Targets the "VAD spuriously armed on near-silence → ASR runs on
# empty buffer → Whisper hallucinates ご視聴ありがとうございました
# / (拍手) / Thanks for watching" failure mode. The gate runs *after*
# the SpeechEnded fires, so it's a pure server-side guard with no
# effect on the start-of-utterance latency.
#
# Set to 0 (or any value >= 0) to disable the gate entirely.
#
# Default: -45
#VAD_MIN_UTTERANCE_RMS_DBFS=-50

# -----------------------------------------------------------------------
# AGENT_SYSTEM_PROMPT — voice-assistant persona, prepended to every
# turn at LLM-invoke time on the `agent` service (LangGraph). Empty
# string disables the system message entirely. Default in
# compose.yaml is the Japanese-first voice-friendly persona; override
# here to change tone, switch primary language, or specialise (e.g.
# "you are a kitchen timer assistant").
#
# The default tells the model:
#   - replies are spoken aloud (no markdown / lists / code blocks)
#   - keep responses short (1–2 sentences)
#   - default to Japanese unless the user clearly speaks another language
#   - maintain a brisk, natural conversational rhythm
#   - keep wording as simple and minimal as possible
#   - skip honorifics (敬語) — speak casually / plain-form
#
# Migration note (issue #10): this used to be ORCH_LLM_SYSTEM_PROMPT
# on the orchestrator. The agent service now owns chat context, so
# the prompt moved here. The orchestrator's ORCH_LLM_SYSTEM_PROMPT is
# pinned to empty in compose.yaml and is ignored even if set —
# remove any old override from your .env.
#
# Single-line only — `.env` files don't support multiline values; if
# you need multi-paragraph instructions, set this in the compose
# environment block directly (which supports YAML literal blocks).
#AGENT_SYSTEM_PROMPT=You are a voice assistant; your replies are spoken aloud, so write the way people speak — no markdown, no lists, no code blocks. Keep every response to one or two short sentences. Default to Japanese (日本語) unless the user clearly speaks another language. Maintain a brisk, natural conversational rhythm. Keep wording as simple and minimal as possible — fewer words is better. Skip honorifics (敬語); use casual / plain-form Japanese (タメ口).

# -----------------------------------------------------------------------
# AGENT_SESSION_IDLE_SEC — seconds of /api/chat silence after which
# the agent rotates the LangGraph thread_id (= conversation memory
# key). The next turn after a rotation starts with empty memory, as
# if it were a fresh conversation.
#
# Voice agent assumes one operator per agent process, so going idle
# is interpreted as "operator walked away". Lower this for a more
# aggressive forget cadence, raise to keep memory across longer
# pauses. Set very high (e.g. 86400) to effectively never rotate
# during a single agent boot.
#
# Default: 600 (10 min)
#AGENT_SESSION_IDLE_SEC=1800
